# ==============================================================================
# Environment Variables Template for {{PROJECT_NAME}}
# Copy this file to '.env' and fill in your local config.
# Do NOT commit '.env' to git!
# ==============================================================================

# Application Environment (development, production, staging)
NODE_ENV=development
APP_PORT=3000

# API Integrations & Keys (Example placeholders)
# ALWAYS load secrets from environment variables, never hardcode them!
# API_SECRET_KEY=your_secret_key_here
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname
